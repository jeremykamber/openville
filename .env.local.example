# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM Provider
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM Provider selection (default: openai)
# Options: openai, openrouter
LLM_PROVIDER=openai

# Admin
MARKET_ADMIN_TOKEN=your-admin-token-here

# Development options (opt-in fallbacks — omit or set to "false" to surface real errors)
USE_MOCK_LLM=false
ALLOW_MOCK_LLM_FALLBACK=true        # enable mock LLM when no real provider is configured
ALLOW_SEEDED_MARKET_FALLBACK=true   # enable seed data when Supabase is empty/unconfigured
ALLOW_KEYWORD_SEARCH_FALLBACK=true  # enable keyword retrieval when embeddings unavailable
